HOST=127.0.0.1
PORT=3101
CAL1CARD_PUBLIC_ORIGIN=https://cal1card.example.com
CAL1CARD_APP_PASSWORD=replace-with-a-long-random-password
CAL1CARD_ENCRYPTION_KEY=replace-with-an-independent-long-random-secret
CAL1CARD_DATA_DIR=/var/lib/cal1card
CAL1CARD_TRUST_PROXY=1
CAL1CARD_WEB_LOGIN_ENABLED=false
CAL1CARD_REMOTE_DISPLAY=99
CAL1CARD_REMOTE_VNC_PORT=5901
PLAYWRIGHT_BROWSERS_PATH=/var/lib/cal1card/ms-playwright
